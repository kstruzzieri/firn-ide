# Wails regenerates these bindings on every build and emits trailing whitespace
# on blank lines, producing perpetual no-op diffs. The `trimws` clean filter
# strips trailing whitespace when git reads the working tree, so regenerated
# whitespace is invisible to `git status`/`git diff` and never gets committed.
#
# Each clone must enable the filter once (CI/passthrough is safe without it):
#   git config filter.trimws.clean "sed -E 's/[[:space:]]+$//'"
frontend/wailsjs/go/*.ts filter=trimws
frontend/wailsjs/**/*.js filter=trimws
